# udder-app environment variables
# Copy to .env and fill in real values. .env is gitignored.

# Groq — used for Whisper speech-to-text transcription (OpenAI-compatible)
# Optional: set TRANSCRIPTION_MODEL=whisper-large-v3 for higher accuracy
GROQ_API_KEY=gsk_...

# Anthropic — used for Claude humor analysis (model: claude-sonnet-5)
ANTHROPIC_API_KEY=sk-ant-...
